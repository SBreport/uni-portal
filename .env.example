# ============================================================
# uni-portal 환경변수 설정 (.env.example)
# 이 파일을 .env로 복사한 후 값을 수정하세요
# Portainer에서는 Stack > Environment variables에 직접 입력 가능
# ============================================================

# 인증 salt (변경 시 기존 비밀번호 모두 무효화됨)
AUTH_SALT=uandi_equipment_2026

# 최초 관리자 계정 (DB에 사용자가 없을 때만 사용)
AUTH_BOOTSTRAP_ADMIN_ID=admin
AUTH_BOOTSTRAP_ADMIN_PW_HASH=9fd94e1caae92307047e2cfb6739f3610fb9a7c7c4924c53f4ae52f88ec7e9ad
AUTH_BOOTSTRAP_ADMIN_ROLE=admin
# 초기 비밀번호: admin1234

# CORS 허용 도메인 (콤마 구분, 미지정 시 localhost 기본)
# 운영 배포 시 실제 도메인으로 설정
# ALLOWED_ORIGINS=https://portal.example.com,https://admin.example.com

# Google Sheets 이벤트 시트 ID (선택사항)
EVENT_SHEET_ID=
