# ============================================================
# uni-portal .gitignore
# ============================================================

# 데이터베이스 (로컬에서 자동 생성됨)
data/*.db
data/*.db-wal
data/*.db-shm
data/backups/

# 인증/비밀 파일 (절대 Git에 올리지 않음)
.streamlit/secrets.toml
credentials.json
.env
*.env

# Claude Code 로컬 설정 (API 키 포함)
.claude/settings.local.json

# 임시 보관 (삭제 대기)
_temp/

# 논문 분석 임시 결과
papers/temp_*.json

# JSON — 데이터/설정 파일은 허용, 민감 파일만 차단
!normalization/*.json
!data/device_master.json
!frontend/package.json
!frontend/package-lock.json
!frontend/tsconfig*.json
!frontend/.vscode/*.json

# 환경 변수
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
*.swp
*.swo

# Node.js (Vue frontend)
frontend/node_modules/
frontend/dist/

# API
api/requirements.txt.bak
.gstack/
