# ============================================================
# uni-portal .gitignore
# ============================================================

# 데이터베이스 (로컬에서 자동 생성됨)
data/*.db
data/*.db-wal
data/*.db-shm
data/backups/

# 인증/비밀 파일 (절대 Git에 올리지 않음)
.streamlit/secrets.toml
credentials.json
*.json
!normalization/*.json

# 환경 변수
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
